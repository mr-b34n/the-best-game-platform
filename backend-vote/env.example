# ==============================================================================
# Voting Service - Environment Variables
# Copy file này thành .env và điền giá trị thật
# ==============================================================================

# PostgreSQL connection string (lấy từ Supabase → Settings → Database → Connection string)
# Dùng connection pooler (port 6543) cho production
DATABASE_URL=postgres://postgres.[project-ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# JWT Secret (lấy từ Supabase → Settings → API → JWT Secret)
JWT_SECRET=your-supabase-jwt-secret

# Port Go service lắng nghe
PORT=8080

# CORS: domain của frontend
ALLOWED_ORIGIN=https://yourdomain.com
